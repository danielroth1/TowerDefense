# ── Tower Defense Deployment Configuration ────────────────────────────────
# Copy this file to .env.deploy and fill in your values.
#   cp .env.example .env.deploy
#
# .env.deploy is listed in .gitignore and will NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# k3s server connection
K3S_SERVER="user@server-ip"
K3S_SSH_PORT="22"

# GitHub Container Registry
YOURUSER="your-github-username"
GHCR_TOKEN="ghp_yourGitHubPersonalAccessTokenHere"
